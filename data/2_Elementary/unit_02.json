"ko": [
  {
    "title": "안녕하세요 여러분!",
    "label": "대화1: 자기소개",
    "script": [
      { "speaker": "A", "text": "안녕하세요. 저는 민수라고 합니다. 이름이 뭐예요?" },
      { "speaker": "B", "text": "영희입니다." },
      { "speaker": "A", "text": "영희 씨는 어디에서 왔어요?" },
      { "speaker": "B", "text": "부산에서 왔어요. 민수 씨는요?" },
      { "speaker": "A", "text": "저는 서울에서 왔어요." }
    ]
  },
  {
    "title": "안녕히 가세요",
    "label": "대화2: 헤어질 때 인사",
    "script": [
      { "speaker": "A", "text": "안녕, 지은아." },
      { "speaker": "B", "text": "안녕, 현우야. 좋은 하루 보내." },
      { "speaker": "A", "text": "고마워. 오늘 저녁에 보자!" },
      { "speaker": "B", "text": "응, 7시에 영화관에서." }
    ]
  },
  {
    "title": "전화 통화",
    "label": "대화3: 가족 안부 묻기",
    "script": [
      { "speaker": "A", "text": "여보세요, 270899입니다." },
