  "grammar_spot": {
    "en": {
      "title": "Present Continuous",
      "rules": [
        "We use the Present Continuous to say what is happening now.",
        "We make the Present Continuous with am/are/is + verb + -ing.",
        "Questions: put am/are/is before the subject.",
        "Negatives: add not after am/are/is.",
        "Short answers: Yes, I am. / No, I'm not."
      ],
      "examples": [
        { "question": "I am studying English.", "answer": "affirmative" },
        { "question": "You are wearing jeans.", "answer": "affirmative" },
        { "question": "She is reading a book.", "answer": "affirmative" },
        { "question": "We are working in class.", "answer": "affirmative" },
        { "question": "They are having lunch.", "answer": "affirmative" },
        { "question": "I'm not staying in a hotel.", "answer": "negative" },
        { "question": "He isn't working.", "answer": "negative" },
        { "question": "We aren't having breakfast.", "answer": "negative" },
        { "question": "What are you wearing?", "answer": "question" },
        { "question": "Where's she staying?", "answer": "question" }
      ]
    },
    "ja": {
      "title": "現在進行形",
      "rules": [
        "現在進行形は、今まさに起こっていることを表します。",
        "現在進行形は am/are/is + 動詞の-ing 形で作ります。",
        "疑問文は am/are/is を主語の前に置きます。",
        "否定文は am/are/is の後に not を付けます。",
        "短い答え：Yes, I am. / No, I'm not."
      ],
      "examples": [
        { "question": "私は英語を勉強しています。", "answer": "肯定" },
        { "question": "あなたはジーンズを履いています。", "answer": "肯定" },
        { "question": "彼女は本を読んでいます。", "answer": "肯定" },
