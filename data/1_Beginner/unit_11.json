  "grammar_spot": {
    "en": {
      "title": "can / can't",
      "rules": [
        "can/can't have the same form for all persons.",
        "There is no do/does in the question.",
        "can = /kən/ in positive and questions, /kæn/ in short answers.",
        "can't = /kɑːnt/ in British English."
      ],
      "examples": [
        { "question": "I/You/He/She/It/We/They can draw.", "answer": "affirmative" },
        { "question": "I/You/He/She/It/We/They can't draw.", "answer": "negative (can't = can not)" },
        { "question": "Can you speak French?", "answer": "Yes, I can. / No, I can't." }
      ],
      "pronunciation": [
        { "text": "He can /kən/ speak Spanish.", "note": "weak form" },
        { "text": "They can't /kɑːnt/ speak Spanish.", "note": "strong form" },
        { "text": "Can /kən/ you speak Spanish?", "note": "weak form" },
        { "text": "Yes, I can /kæn/.", "note": "strong form" }
      ]
    },
    "ja": {
      "title": "can / can't",
      "rules": [
        "can/can't は全ての人称で同じ形です。",
        "疑問文には do/does を使いません。",
        "can は肯定文と疑問文で /kən/、短い答えで /kæn/ と発音します。",
        "can't はイギリス英語で /kɑːnt/ と発音します。"
