  "grammar_spot": {
    "en": {
      "title": "Past Simple Questions and Negatives",
      "rules": [
        "We make questions with 'did' for all persons.",
        "We make negatives with 'did not' or 'didn't' for all persons.",
        "The main verb stays in the base form (infinitive without 'to').",
        "We use 'did' in Past Simple and 'do/does' in Present Simple."
      ],
      "examples": [
        { "question": "Did you get up early?", "answer": "Yes, I did." },
        { "question": "Did she get up early?", "answer": "No, she didn't." },
        { "question": "We didn't go to work.", "answer": "didn't = did not" },
        { "question": "They didn't go to work.", "answer": "" }
      ],
      "comparison": [
        { "present": "What do you do every morning?", "past": "What did you do yesterday morning?" },
        { "present": "She doesn't play tennis every Sunday.", "past": "She didn't play tennis last Sunday." }
      ],
