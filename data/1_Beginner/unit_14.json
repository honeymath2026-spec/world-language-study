  "grammar_spot": {
    "en": {
      "title": "Present Continuous for Future",
      "rules": [
        "The Present Continuous can express future plans.",
        "We often say when (this afternoon, tomorrow, on Saturday, ...) with the Present Continuous.",
        "Make questions with When + am/are/is + subject + -ing.",
        "The Present Continuous can express present and future.",
        "Compare: I'm reading about Mexico. (now) / I'm leaving next Friday. (future)"
      ],
      "examples": [
        { "question": "I'm going to Mexico next week.", "answer": "future plan" },
        { "question": "She's seeing the doctor on Wednesday.", "answer": "future plan" },
        { "question": "We're leaving next Friday.", "answer": "future plan" },
        { "question": "What are you doing tomorrow?", "answer": "future question" },
        { "question": "When are you leaving?", "answer": "future question" },
        { "question": "Where are you going?", "answer": "future question" },
        { "question": "I'm reading about Mexico.", "answer": "present action" }
      ]
    },
    "ja": {
      "title": "未来の現在進行形",
      "rules": [
        "現在進行形は未来の計画を表現できます。",
        "現在進行形と一緒にいつ（今日の午後、明日、土曜日に...）をよく言います。",
        "When + am/are/is + 主語 + -ing で疑問文を作ります。",
        "現在進行形は現在と未来の両方を表現できます。",
